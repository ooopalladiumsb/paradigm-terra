{
  "name": "@paradigm-terra/cal",
  "version": "0.1.0",
  "description": "Immutable, hashable foundation of the Constitutional Action Language (CAL v0.1.0-draft): wire-format validation, CAL_HASH, signing payload, event/receipt hashing, lifecycle types. Reducer and gas phases layer on top later.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "vectors",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "vectors:generate": "node --import tsx scripts/generate-vectors.ts",
    "vectors:verify": "node --import tsx --test test/golden-vectors.test.ts"
  },
  "dependencies": {
    "@paradigm-terra/canonical": "file:../canonical",
    "@paradigm-terra/dsl": "file:../dsl"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
