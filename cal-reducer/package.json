{
  "name": "@paradigm-terra/cal-reducer",
  "version": "0.1.0",
  "description": "Deterministic CAL event reducer (CAL v0.1.0-draft §7.1): apply(State, Event) -> State as a pure total fold, with per-CAL effect staging. Gas pricing and validator decision logic are separate phases; events are self-describing.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src", "vectors", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "vectors:generate": "node --import tsx scripts/generate-vectors.ts",
    "vectors:verify": "node --import tsx --test test/golden-vectors.test.ts"
  },
  "dependencies": {
    "@paradigm-terra/canonical": "file:../canonical",
    "@paradigm-terra/cal": "file:../cal"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
