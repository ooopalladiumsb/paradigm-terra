{
  "name": "@paradigm-terra/canonical",
  "version": "0.1.0",
  "description": "Reference implementation of Paradigm Terra Canonical Encoding Specification v1.3 (SCF) with v0.10.0-draft domain tag extensions.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "vectors",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "vectors:generate": "node --import tsx scripts/generate-vectors.ts",
    "vectors:verify": "node --import tsx --test test/golden-vectors.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
